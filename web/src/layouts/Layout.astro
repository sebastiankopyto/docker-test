---
// Wspólny szkielet strony — ta sama stylistyka co pierwotna wizytówka.
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Prosta strona-wizytówka na Astro.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <main class="card">
      <slot />
    </main>
  </body>
</html>

<style is:global>
  :root {
    --bg: #0f172a;
    --card: #1e293b;
    --text: #e2e8f0;
    --muted: #94a3b8;
    --accent: #38bdf8;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }
  .card {
    background: var(--card);
    max-width: 480px;
    width: 100%;
    padding: 2.5rem 2rem;
    border-radius: 16px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
    text-align: center;
  }
  h1 { font-size: 1.9rem; margin-bottom: 0.25rem; }
  a { color: var(--accent); }
  .tagline { color: var(--accent); font-weight: 600; margin-bottom: 1.5rem; }
  .bio { color: var(--muted); line-height: 1.6; margin-bottom: 1.75rem; }
  nav { display: flex; gap: 1rem; justify-content: center; margin-top: 1.5rem; }
  nav a {
    text-decoration: none;
    padding: 0.5rem 1rem;
    border: 1px solid rgba(148, 163, 184, 0.25);
    border-radius: 8px;
  }
  nav a:hover { border-color: var(--accent); }
  ul.posts { list-style: none; text-align: left; }
  ul.posts li { padding: 0.6rem 0; border-bottom: 1px solid rgba(148,163,184,0.15); }
  .muted { color: var(--muted); font-size: 0.85rem; }
  article { text-align: left; }
  article h1 { text-align: center; }
  .rebuild {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(148, 163, 184, 0.15);
  }
  button {
    cursor: pointer;
    background: var(--accent);
    color: #06202b;
    border: none;
    padding: 0.6rem 1.1rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
  }
  button:disabled { opacity: 0.5; cursor: default; }
  pre {
    white-space: pre-wrap;
    text-align: left;
    font-size: 0.8rem;
    margin-top: 0.75rem;
  }
</style>
